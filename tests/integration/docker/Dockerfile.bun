FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    unzip \
    xz-utils \
  && rm -rf /var/lib/apt/lists/*

# Install Node.js + npm for npm-only capability dependency installation
RUN curl -fsSLO "https://nodejs.org/dist/v22.13.0/node-v22.13.0-linux-x64.tar.xz" \
  && tar -xJf "node-v22.13.0-linux-x64.tar.xz" -C /usr/local --strip-components=1 \
  && rm "node-v22.13.0-linux-x64.tar.xz" \
  && node --version \
  && npm --version

# Install Bun
ENV BUN_INSTALL=/usr/local/bun
RUN mkdir -p "${BUN_INSTALL}" \
  && curl -fsSL https://bun.sh/install | bash

ENV PATH="/usr/local/bun/bin:${PATH}"

WORKDIR /repo
